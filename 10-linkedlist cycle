class ListNode:
    def __init__(self, x):
        self.val = x
        self.next = None

class Solution:
    def hasCycle(self, head: Optional[ListNode]) -> bool:
        if head == None or head.next == None:
            return False
        else:
            present = set()
            node = head
            while(node not in present and node.next != None):
                present.add(node)
                node = node.next
            if node in present and node.next!=None:
                return True
            if node.next == None :
                return False


        
