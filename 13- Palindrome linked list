class Solution:
    def isPalindrome(self, head: Optional[ListNode]) -> bool:
        if head is None or head.next is None:
            return True

        # Find middle
        fast = head
        slow = head

        while fast.next and fast.next.next:
            slow = slow.next
            fast = fast.next.next

        # Reverse second half
        node1 = None
        node2 = slow.next

        while node2:
            next_move = node2.next
            node2.next = node1
            node1 = node2
            node2 = next_move

        # Compare
        start = head
        end = node1

        while end:
            if start.val != end.val:
                return False
            start = start.next
            end = end.next

        return True
