'''
class Node:
    def __init__(self, data): 
        self.data = data
        self.next = None
'''
class Solution:
    def lengthOfLoop(self, head):
        if head == None or head.next == None:
            return 0
        else:
            node = head
            visited = {}
            found = 0
            while(node not in visited and node.next != None):
                visited[node] = found
                found += 1
                node = node.next
            if node in visited and node.next != None:
                return found - visited[node]
            if node.next == None:
                return 0
        
