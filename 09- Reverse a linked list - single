class ListNode:
    def __init__(self, val=0, next=None):
        self.val = val
        self.next = next
class Solution:
    def reverseList(self, head: Optional[ListNode]) -> Optional[ListNode]:
        if head == None:
            return head
        elif head.next == None:
            return head
        else:
            # beginning
            node = head
            head = head.next
            next_move = head.next
            node.next = None
            head.next = node
            # middle nodes
            while(next_move != None):
                node = head
                head = next_move
                next_move = head.next
                head.next = node
            return head


