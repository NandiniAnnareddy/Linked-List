
class Node:
    def __init__(self, data):
        self.data = data
        self.next = None
        
class Solution:
    def searchKey(self, head, key):
        node = head
        while(node.next != None):
            if node.data == key:
                return True
            node = node.next
        if node.data == key:
            return True
        else:
            return False
